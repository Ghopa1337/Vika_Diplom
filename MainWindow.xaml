<Window x:Class="CargoTransport.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CargoTransport.Desktop.ViewModels"
        xmlns:behaviors="clr-namespace:CargoTransport.Desktop.Behaviors"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:CargoTransport.Desktop.ViewModels"
        xmlns:views="clr-namespace:CargoTransport.Desktop.Views"
        mc:Ignorable="d"
        Title="Система учета грузоперевозок"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Style="{StaticResource MaterialDesignWindow}">
    <Window.Resources>
        <Style x:Key="SectionDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#E5ECF1" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F5" />
            <Setter Property="VerticalGridLinesBrush" Value="#EEF2F5" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="#51606D" />
                        <Setter Property="Background" Value="#F5F8FB" />
                        <Setter Property="BorderBrush" Value="#F5F8FB" />
                        <Setter Property="Padding" Value="14,12" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="14,12" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Foreground" Value="#22303A" />
                        <Setter Property="FontSize" Value="13" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CrudTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="MinWidth" Value="190" />
        </Style>

        <Style x:Key="CrudComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="MinWidth" Value="190" />
        </Style>

        <Style x:Key="CrudButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="MinWidth" Value="110" />
        </Style>

        <Style x:Key="SectionExpanderStyle" TargetType="Expander">
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <DataTemplate DataType="{x:Type viewModels:OrderWizardViewModel}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Пошаговое создание заказа"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#22303A" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Сценарий заменяет ручное создание через CRUD-форму: сначала груз, затем маршрут и только потом расчет или назначение."
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="#687683" />

                    <StackPanel Margin="0,20,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <StackPanel Width="120">
                            <Ellipse Width="34"
                                     Height="34"
                                     HorizontalAlignment="Center"
                                     Fill="{Binding CurrentStep, Converter={local:StepToColorConverter}, ConverterParameter=1}"
                                     Stroke="#0F5C69"
                                     StrokeThickness="2" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="Груз"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#50606D" />
                        </StackPanel>

                        <Rectangle Width="56"
                                   Height="2"
                                   VerticalAlignment="Center"
                                   Fill="#C8D6DF" />

                        <StackPanel Width="120">
                            <Ellipse Width="34"
                                     Height="34"
                                     HorizontalAlignment="Center"
                                     Fill="{Binding CurrentStep, Converter={local:StepToColorConverter}, ConverterParameter=2}"
                                     Stroke="#0F5C69"
                                     StrokeThickness="2" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="Маршрут"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#50606D" />
                        </StackPanel>

                        <Rectangle Width="56"
                                   Height="2"
                                   VerticalAlignment="Center"
                                   Fill="#C8D6DF" />

                        <StackPanel Width="120">
                            <Ellipse Width="34"
                                     Height="34"
                                     HorizontalAlignment="Center"
                                     Fill="{Binding CurrentStep, Converter={local:StepToColorConverter}, ConverterParameter=3}"
                                     Stroke="#0F5C69"
                                     StrokeThickness="2" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="Назначение"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#50606D" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1"
                        CornerRadius="24"
                        Background="#F8FBFD"
                        BorderBrush="#E6EEF3"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="22">
                            <StackPanel Visibility="{Binding CurrentStep, Converter={local:StepToVisibilityConverter}, ConverterParameter=1}">
                                <TextBlock Text="Шаг 1. Получатель и груз"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#22303A" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="Выберите получателя и заполните параметры нового груза. При необходимости можно взять уже существующий груз из справочника."
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="#687683" />

                                <ComboBox Margin="0,18,0,0"
                                          SelectedValue="{Binding SelectedReceiverUserId}"
                                          IsEnabled="{Binding IsReceiverSelectionEnabled}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding ReceiverOptions}"
                                          materialDesign:HintAssist.Hint="Получатель" />

                                <CheckBox Margin="0,18,0,0"
                                          Content="Создать новый груз"
                                          IsChecked="{Binding IsNewCargo}" />

                                <StackPanel Margin="0,18,0,0"
                                            Visibility="{Binding IsNewCargo, Converter={local:BooleanToVisibilityConverter}}">
                                    <UniformGrid Columns="2">
                                        <TextBox Margin="0,0,10,10"
                                                 Text="{Binding CargoName, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Наименование груза" />
                                        <ComboBox Margin="0,0,10,10"
                                                  SelectedValue="{Binding SelectedCargoType}"
                                                  SelectedValuePath="Tag"
                                                  materialDesign:HintAssist.Hint="Тип груза">
                                            <ComboBoxItem Content="Обычный" Tag="normal" />
                                            <ComboBoxItem Content="Опасный" Tag="hazardous" />
                                            <ComboBoxItem Content="Скоропортящийся" Tag="perishable" />
                                            <ComboBoxItem Content="Крупногабаритный" Tag="oversized" />
                                        </ComboBox>
                                        <TextBox Margin="0,0,10,10"
                                                 Text="{Binding CargoWeight, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Вес, кг" />
                                        <TextBox Margin="0,0,10,10"
                                                 Text="{Binding CargoVolume, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Объем, м3" />
                                    </UniformGrid>

                                    <TextBox Height="84"
                                             Text="{Binding SpecialRequirements, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             materialDesign:HintAssist.Hint="Особые требования к перевозке" />
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0"
                                            Visibility="{Binding IsNewCargo, Converter={local:InverseBooleanToVisibilityConverter}}">
                                    <ComboBox SelectedValue="{Binding SelectedExistingCargoId}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding CargoOptions}"
                                              materialDesign:HintAssist.Hint="Груз из справочника" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding CurrentStep, Converter={local:StepToVisibilityConverter}, ConverterParameter=2}">
                                <TextBlock Text="Шаг 2. Маршрут и контакты"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#22303A" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="Заполните точки маршрута, контактных лиц и при необходимости укажите плановые даты."
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="#687683" />

                                <UniformGrid Margin="0,18,0,0" Columns="2">
                                    <TextBox Margin="0,0,10,10"
                                             Text="{Binding PickupAddress, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Адрес погрузки" />
                                    <TextBox Margin="0,0,10,10"
                                             Text="{Binding DeliveryAddress, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Адрес доставки" />
                                    <TextBox Margin="0,0,10,10"
                                             Text="{Binding PickupContactName, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Контакт на погрузке" />
                                    <TextBox Margin="0,0,10,10"
                                             Text="{Binding DeliveryContactName, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Контакт на доставке" />
                                    <TextBox Margin="0,0,10,10"
                                             Text="{Binding PickupContactPhone, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Телефон погрузки" />
                                    <TextBox Margin="0,0,10,10"
                                             Text="{Binding DeliveryContactPhone, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Телефон доставки" />
                                    <DatePicker Margin="0,0,10,10"
                                                SelectedDate="{Binding PlannedPickupAt}"
                                                materialDesign:HintAssist.Hint="План погрузки" />
                                    <DatePicker Margin="0,0,10,10"
                                                SelectedDate="{Binding DesiredDeliveryAt}"
                                                materialDesign:HintAssist.Hint="Желаемая доставка" />
                                </UniformGrid>

                                <TextBox Height="84"
                                         Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         materialDesign:HintAssist.Hint="Комментарий к заказу" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding CurrentStep, Converter={local:StepToVisibilityConverter}, ConverterParameter=3}">
                                <TextBlock Text="Шаг 3. Расчет и назначение"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#22303A" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="Стоимость можно оставить пустой и заполнить позже. Если выбрать и водителя, и транспорт, заказ будет создан со статусом «Назначен»."
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Foreground="#687683" />

                                <UniformGrid Margin="0,18,0,0" Columns="2">
                                    <TextBox Margin="0,0,10,10"
                                             Text="{Binding DistanceKm, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Расстояние, км" />
                                    <TextBox Margin="0,0,10,10"
                                             Text="{Binding TotalCost, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Стоимость перевозки" />
                                    <ComboBox Margin="0,0,10,10"
                                              SelectedValue="{Binding SelectedDriverId}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding DriverOptions}"
                                              Visibility="{Binding IsAssignmentVisible, Converter={local:BooleanToVisibilityConverter}}"
                                              materialDesign:HintAssist.Hint="Водитель" />
                                    <ComboBox Margin="0,0,10,10"
                                              SelectedValue="{Binding SelectedVehicleId}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding VehicleOptions}"
                                              Visibility="{Binding IsAssignmentVisible, Converter={local:BooleanToVisibilityConverter}}"
                                              materialDesign:HintAssist.Hint="Транспорт" />
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Foreground="#0F5C69" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Width="110"
                                Margin="0,0,10,0"
                                Command="{Binding BackCommand}"
                                Content="Назад" />
                        <Button Width="110"
                                Margin="0,0,10,0"
                                Command="{Binding NextCommand}"
                                Content="Далее"
                                Visibility="{Binding CurrentStep, Converter={local:StepToVisibilityConverter}, ConverterParameter=NotLast}" />
                        <Button Width="160"
                                Background="#D8F3E3"
                                Command="{Binding CompleteCommand}"
                                Content="Создать заказ"
                                Visibility="{Binding CurrentStep, Converter={local:StepToVisibilityConverter}, ConverterParameter=3}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:OrderDetailsViewModel}">
            <views:OrderDetailsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:UserProfileSectionViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,18,0" Padding="26" CornerRadius="24" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="#22303A" />
                            <TextBlock Margin="0,12,0,0" Text="{Binding Subtitle}" FontSize="14" LineHeight="22" TextWrapping="Wrap" Foreground="#687683" />
                            <WrapPanel Margin="0,18,0,0">
                                <Button Margin="0,0,10,0" Command="{Binding RefreshCommand}" Content="Обновить" Style="{StaticResource MaterialDesignOutlinedButton}" />
                                <TextBlock Margin="8,8,0,0" Text="{Binding StatusMessage}" Foreground="#0F5C69" TextWrapping="Wrap" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="24" CornerRadius="24" Background="#F5FBFB" BorderBrush="#D5ECEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Учетная запись" FontSize="14" FontWeight="SemiBold" Foreground="#0F5C69" />
                            <TextBlock Margin="0,10,0,0" Text="{Binding Username}" FontSize="20" FontWeight="SemiBold" Foreground="#22303A" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding RoleName}" FontSize="13" Foreground="#4E7B81" />
                            <TextBlock Margin="0,14,0,0" Text="{Binding AccountStatus}" FontSize="13" FontWeight="SemiBold" Foreground="#0F5C69" />
                            <Border Margin="0,14,0,0" Padding="12" CornerRadius="14" Background="#FFF4E6" Visibility="{Binding MustChangePassword, Converter={local:BooleanToVisibilityConverter}}">
                                <TextBlock Text="Для учетной записи включено требование сменить пароль." TextWrapping="Wrap" Foreground="#815B19" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Padding="24" CornerRadius="24" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Контактные данные" FontSize="20" FontWeight="SemiBold" Foreground="#22303A" />
                                <TextBlock Margin="0,8,0,18" Text="Эти данные видит диспетчер при работе с заказом и рейсом." Foreground="#687683" />

                                <UniformGrid Columns="2">
                                    <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="ФИО / контактное лицо" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Компания" Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Email" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Телефон" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
                                </UniformGrid>

                                <Button Margin="0,8,0,0" Width="170" HorizontalAlignment="Left" Command="{Binding SaveProfileCommand}" Content="Сохранить профиль" Style="{StaticResource MaterialDesignRaisedButton}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0" Padding="24" CornerRadius="24" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Смена пароля" FontSize="20" FontWeight="SemiBold" Foreground="#22303A" />
                                <TextBlock Margin="0,8,0,18" Text="Отдельный безопасный сценарий: текущий пароль проверяется, старый хэш сохраняется в истории." Foreground="#687683" TextWrapping="Wrap" />

                                <UniformGrid Columns="3">
                                    <PasswordBox Margin="0,0,10,10"
                                                 MinWidth="190"
                                                 behaviors:PasswordBoxAssistant.BindPassword="True"
                                                 behaviors:PasswordBoxAssistant.BoundPassword="{Binding CurrentPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Текущий пароль" />
                                    <PasswordBox Margin="0,0,10,10"
                                                 MinWidth="190"
                                                 behaviors:PasswordBoxAssistant.BindPassword="True"
                                                 behaviors:PasswordBoxAssistant.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Новый пароль" />
                                    <PasswordBox Margin="0,0,10,10"
                                                 MinWidth="190"
                                                 behaviors:PasswordBoxAssistant.BindPassword="True"
                                                 behaviors:PasswordBoxAssistant.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Повтор пароля" />
                                </UniformGrid>

                                <WrapPanel Margin="0,8,0,0">
                                    <Button Margin="0,0,10,0" Width="170" Command="{Binding ChangePasswordCommand}" Content="Сменить пароль" Style="{StaticResource MaterialDesignRaisedButton}" />
                                    <Button Command="{Binding ClearPasswordCommand}" Content="Очистить поля" Style="{StaticResource MaterialDesignOutlinedButton}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Margin="0,0,18,0" Padding="20" CornerRadius="22" Background="#F7FAFC" BorderBrush="#E8EEF2" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Активность" FontSize="16" FontWeight="SemiBold" Foreground="#22303A" />
                                    <TextBlock Margin="0,10,0,0" Text="{Binding LastLoginLabel, StringFormat=Последний вход: {0}}" Foreground="#687683" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding CreatedAtLabel, StringFormat=Создан: {0}}" Foreground="#687683" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding UpdatedAtLabel, StringFormat=Обновлен: {0}}" Foreground="#687683" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Padding="20" CornerRadius="22" Background="#F7FAFC" BorderBrush="#E8EEF2" BorderThickness="1" Visibility="{Binding IsDriverProfileVisible, Converter={local:BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Данные водителя" FontSize="16" FontWeight="SemiBold" Foreground="#22303A" />
                                    <TextBlock Margin="0,10,0,0" Text="{Binding DriverLicenseLabel, StringFormat=ВУ: {0}}" Foreground="#687683" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding DriverStatusLabel, StringFormat=Статус: {0}}" Foreground="#687683" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:UserNotificationsSectionViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Margin="0,0,0,18" Padding="26" CornerRadius="24" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="#22303A" />
                            <TextBlock Margin="0,10,0,0" Text="{Binding Subtitle}" FontSize="14" LineHeight="22" TextWrapping="Wrap" Foreground="#687683" />
                            <TextBlock Margin="0,12,0,0" Text="{Binding StatusMessage}" Foreground="#0F5C69" TextWrapping="Wrap" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                            <CheckBox Margin="0,0,12,0" VerticalAlignment="Center" Content="Только непрочитанные" IsChecked="{Binding UnreadOnly, Mode=TwoWay}" />
                            <Button Margin="0,0,10,0" Command="{Binding ApplyFilterCommand}" Content="Фильтр" Style="{StaticResource MaterialDesignOutlinedButton}" />
                            <Button Command="{Binding ClearFilterCommand}" Content="Очистить" Style="{StaticResource MaterialDesignOutlinedButton}" />
                        </WrapPanel>
                    </Grid>
                </Border>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Metrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,16,16" Padding="18" CornerRadius="18" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#6A7784" />
                                    <TextBlock Margin="0,8,0,0" Text="{Binding Value}" FontSize="22" FontWeight="SemiBold" Foreground="#1E2B35" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding Hint}" TextWrapping="Wrap" FontSize="12" Foreground="#6A7784" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,18,0" CornerRadius="22" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                        <DataGrid ItemsSource="{Binding Notifications}"
                                  SelectedItem="{Binding SelectedNotification, Mode=TwoWay}"
                                  Style="{StaticResource SectionDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Статус" Binding="{Binding ReadState}" Width="0.8*" />
                                <DataGridTextColumn Header="Тип" Binding="{Binding TypeName}" Width="0.9*" />
                                <DataGridTextColumn Header="Заголовок" Binding="{Binding Title}" Width="1.6*" />
