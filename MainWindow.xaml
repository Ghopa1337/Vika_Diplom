<Window x:Class="CargoTransport.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Система учета грузоперевозок"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}">
    <DockPanel Background="#F4F7FB">
        <Border DockPanel.Dock="Top"
                Background="#0F5C69"
                Padding="28,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding Subtitle}"
                               FontSize="14"
                               Foreground="#D9F0F1" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="18,10"
                        CornerRadius="18"
                        Background="#1C7583"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentUserName}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding CurrentUserRole}"
                                   FontSize="12"
                                   Foreground="#CFECEF" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <UniformGrid Columns="3" Margin="0,0,0,24">
                <Border Margin="0,0,16,0"
                        Padding="20"
                        CornerRadius="20"
                        Background="White"
                        materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="Статус подключения"
                                   FontSize="13"
                                   Foreground="#6A7784" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="MariaDB подключена"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#0F5C69" />
                    </StackPanel>
                </Border>

                <Border Margin="0,0,16,0"
                        Padding="20"
                        CornerRadius="20"
                        Background="White"
                        materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="Текущий этап"
                                   FontSize="13"
                                   Foreground="#6A7784" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Авторизация и стартовый каркас"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="#22303A" />
                    </StackPanel>
                </Border>

                <Border Padding="20"
                        CornerRadius="20"
                        Background="White"
                        materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="Что дальше"
                                   FontSize="13"
                                   Foreground="#6A7784" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Заказы, пользователи, транспорт, водители"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="#22303A" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="1"
                    Padding="28"
                    CornerRadius="24"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Пустое главное окно"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#22303A" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding PlaceholderText}"
                               FontSize="15"
                               Foreground="#5D6B78"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
