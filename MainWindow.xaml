                                <Button Style="{StaticResource CrudButtonStyle}" Content="Новый" Command="{Binding BeginCreateCommand}" />
                                <Button Style="{StaticResource CrudButtonStyle}" Content="Сохранить" Command="{Binding SaveCommand}" />
                                <Button Style="{StaticResource CrudButtonStyle}" Content="Удалить" Command="{Binding DeleteCommand}" />
                                <Button Style="{StaticResource CrudButtonStyle}" Content="Сброс" Command="{Binding ResetCommand}" />
                                <TextBlock Margin="8,8,0,0" Text="{Binding StatusMessage}" Foreground="#0F5C69" TextWrapping="Wrap" />
                            </WrapPanel>

                            <UniformGrid Columns="4">
                                <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Госномер" Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Модель" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Грузоподъемность, кг" Text="{Binding CapacityKg, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Объем, м3" Text="{Binding VolumeM3, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox Style="{StaticResource CrudComboBoxStyle}" materialDesign:HintAssist.Hint="Тип кузова" ItemsSource="{Binding BodyTypeOptions}" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding SelectedBodyTypeCode, Mode=TwoWay}" />
                                <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Год выпуска" Text="{Binding ProductionYear, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox Style="{StaticResource CrudComboBoxStyle}" materialDesign:HintAssist.Hint="Статус" ItemsSource="{Binding StatusOptions}" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding SelectedStatusCode, Mode=TwoWay}" />
                                <ComboBox Style="{StaticResource CrudComboBoxStyle}" materialDesign:HintAssist.Hint="Закрепленный водитель" ItemsSource="{Binding DriverOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding SelectedCurrentDriverId, Mode=TwoWay}" />
                                <DatePicker Margin="0,0,10,10" materialDesign:HintAssist.Hint="Страховка до" SelectedDate="{Binding InsuranceExpiry, Mode=TwoWay}" />
                                <TextBox Style="{StaticResource CrudTextBoxStyle}" materialDesign:HintAssist.Hint="Заметки" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Expander>
                </Grid>

                <Border Grid.Row="2" Margin="0,10,0,0" CornerRadius="24" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                    <DataGrid Style="{StaticResource SectionDataGridStyle}" ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Госномер" Binding="{Binding LicensePlate}" Width="1.1*" />
                            <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="1.7*" />
                            <DataGridTextColumn Header="Тип кузова" Binding="{Binding BodyType}" Width="1.2*" />
                            <DataGridTextColumn Header="Грузоподъемность" Binding="{Binding Capacity}" Width="1.2*" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="1.1*" />
                            <DataGridTextColumn Header="Закрепленный водитель" Binding="{Binding AssignedDriver}" Width="1.5*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:AdminReportsSectionViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ItemsControl ItemsSource="{Binding Stats}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,16,16" Padding="20" CornerRadius="20" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#6A7784" />
                                    <TextBlock Margin="0,10,0,0" Text="{Binding Value}" FontSize="24" FontWeight="SemiBold" Foreground="#1E2B35" />
                                    <TextBlock Margin="0,8,0,0" Text="{Binding Hint}" FontSize="13" TextWrapping="Wrap" Foreground="#6A7784" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.Row="1" Margin="0,18,0,0" ItemsSource="{Binding Reports}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="310" Margin="0,0,18,18" Padding="24" CornerRadius="24" Background="White" BorderBrush="#E8EEF2" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Foreground="#22303A" />
                                    <TextBlock Margin="0,10,0,0" Text="{Binding Description}" TextWrapping="Wrap" FontSize="13" LineHeight="22" Foreground="#687683" />
                                    <Border Margin="0,18,0,0" Padding="10,6" HorizontalAlignment="Left" CornerRadius="14" Background="#E8F5F7">
                                        <TextBlock Text="{Binding Format}" FontSize="12" FontWeight="SemiBold" Foreground="#0F5C69" />
                                    </Border>
                                    <TextBlock Margin="0,14,0,0" Text="{Binding Freshness}" FontSize="12" Foreground="#6A7784" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#EEF3F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="18"
                CornerRadius="32">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0E4F59" Offset="0" />
                    <GradientStop Color="#176C7A" Offset="0.55" />
                    <GradientStop Color="#4D98A2" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="28,28,28,18">
                    <TextBlock Text="Cargo"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Margin="0,10,0,0"
                               Text="{Binding ShellSubtitle}"
                               FontSize="14"
                               LineHeight="22"
                               TextWrapping="Wrap"
                               Foreground="#D8F1F2" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="28,0,28,22"
                        Padding="18"
                        CornerRadius="22"
                        Background="#18000000">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentUserName}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding CurrentUserRole}"
                                   FontSize="13"
                                   Foreground="#D8F1F2" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding SessionLabel}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="#C6E8EA" />
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="2"
                         Margin="20,0,20,0"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,10" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Foreground" Value="#D7F1F2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="NavigationItemBorder"
                                                Padding="18,16"
                                                CornerRadius="20"
                                                Background="#13000000">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="NavigationItemBorder" Property="Background" Value="#F4C95D" />
                                                <Setter Property="Foreground" Value="#17313A" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="NavigationItemBorder" Property="Background" Value="#24FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding Subtitle}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Padding="10,4"
                                        CornerRadius="12"
                                        Background="#1AFFFFFF"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Badge}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="3"
                        Margin="28,18,28,28"
                        Padding="18"
                        CornerRadius="22"
                        Background="#18000000">
                    <StackPanel>
                        <TextBlock Text="Подключение"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="MariaDB / локальный сервер"
                                   FontSize="13"
                                   Foreground="#D8F1F2" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding CurrentUserLogin}"
                                   FontSize="12"
                                   Foreground="#C6E8EA" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="0,18,18,18"
                Padding="26"
                CornerRadius="30"
                Background="White"
                BorderBrush="#E5ECF1"
                BorderThickness="1"
                materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding SelectedNavigationTitle}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#22303A" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding SelectedNavigationSubtitle}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Foreground="#6B7985" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="18,0,0,0"
                            Padding="16,10"
                            CornerRadius="18"
                            Background="#F6FAFC"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Сегодня"
                                       FontSize="11"
                                       Foreground="#6A7784" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding TodayLabel}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#22303A" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="14,0,0,0"
                            Padding="18,10"
                            CornerRadius="18"
                            Background="#E8F5F7"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentUserName}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#0F5C69" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="{Binding CurrentUserRole}"
                                       FontSize="12"
                                       Foreground="#4E7B81" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <!-- Background Content -->
                    <Border Margin="0,26,0,0"
                            Padding="24"
                            CornerRadius="26"
                            Background="#F8FBFD">
                        <ContentPresenter Content="{Binding SelectedContent}" />
                    </Border>

                    <!-- Modal Overlay -->
                    <Grid Visibility="{Binding ActiveModalContent, Converter={local:NullToVisibilityConverter}}">
                        <Border Background="#40000000" />
                        <Border Background="White"
                                CornerRadius="24"
                                Width="1040"
                                Height="720"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                BorderBrush="#E5ECF1"
                                BorderThickness="1">
                            <Grid>
                                <Button Width="34"
                                        Height="34"
                                        Margin="0,12,12,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Panel.ZIndex="2"
                                        Command="{Binding CloseModalCommand}"
                                        Content="×"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                <ContentPresenter Margin="0,42,0,0"
                                                  Content="{Binding ActiveModalContent}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
